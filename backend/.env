# Copia este archivo a backend/.env y completa los valores.
# NUNCA subas backend/.env al repositorio (ya está en .gitignore).

# --- Servidor ---
PORT=3000
NODE_ENV=development

# --- PostgreSQL ---
# El usuario/rol necesita permisos para crear la base de datos indicada en
# PGDATABASE si esta todavía no existe (o crea la base de datos tú mismo
# de antemano y usa un usuario con permisos sobre ella).
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=Gadiel01
PGDATABASE=Datos
# "true" si tu proveedor de PostgreSQL requiere SSL (ej. bases de datos
# administradas en la nube). En local normalmente es "false".
PGSSL=false

# --- Autenticación (JWT) ---
# Obligatorio. Genera un valor largo y aleatorio, por ejemplo con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=sedir_jwt_secret_change_this_in_production_2026
# Duración del token de sesión. Formato aceptado por la librería `jsonwebtoken`.
JWT_EXPIRES_IN=8h

# --- Usuario administrador inicial ---
# `npm run db:init` crea automáticamente este usuario si no existe todavía.
# Si no defines ADMIN_PASSWORD, se genera una contraseña aleatoria y se
# imprime una sola vez en la consola durante la inicialización.
ADMIN_EMAIL=admin@sedir.local
ADMIN_NOMBRE=admin
ADMIN_PASSWORD=

# --- Catálogo de ejemplo (opcional) ---
# Si es "true", `npm run db:init` siembra un catálogo de productos de
# ejemplo (miel, plantones, etc.). Déjalo en "false" en producción: el
# catálogo real se gestiona desde el panel de administración. Útil solo
# para levantar un entorno de desarrollo con datos de muestra.
SEED_DEMO_DATA=false

# --- Notificación por correo del formulario de contacto (opcional) ---
# Si se completan estas variables, cada mensaje de /api/contacto además de
# guardarse en la base de datos se notifica por correo a CONTACT_EMAIL_TO.
# Si se dejan vacías, el mensaje igual se guarda en la base de datos, solo
# que no se envía la notificación por correo.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
CONTACT_EMAIL_TO=secretaria@sedir.org.pe

# --- Conexión MySQL (opcional) ---
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=sedirorg_db
DB_USERNAME=sedirorg_userisi
DB_PASSWORD=Hhv7x63Kt9D

# --- CORS (opcional) ---
# Solo necesario si el frontend se sirve desde un origen distinto al del
# backend (por defecto el backend sirve el frontend estático desde /public
# en el mismo origen, así que esto puede dejarse vacío). Lista de orígenes
# permitidos separados por comas, ej:
# ALLOWED_ORIGINS=http://localhost:5500,https://sedir.example.com
ALLOWED_ORIGINS=

WEATHERLINK_API_KEY=cgzb0qzn3lu6aqtspy8k3fsnvkgvafkh
WEATHERLINK_API_SECRET=wrqth4msfb1ztedszxg1h4liibr3tfxs
WEATHERLINK_STATION_ID=